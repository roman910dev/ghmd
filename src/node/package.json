{
  "name": "ghmd-js",
  "version": "1.0.1",
  "description": "A simple CLI to convert markdown files to HTML using GitHub API using the GitHub Markdown style.",
  "author": "Román Via-Dufrese Saus <roman910dev@gmail.com>",
  "homepage": "https://github.com/roman910dev/ghmd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roman910dev/ghmd.git"
  },
  "bugs": {
    "url": "https://github.com/roman910dev/ghmd/issues"
  },
  "license": "MIT",
  "keywords": [
    "markdown",
    "github",
    "cli",
    "html",
    "converter"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp -R shared dist/shared && chmod +x dist/cli.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bin": {
    "ghmd": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=18"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
